{
  "name": "create-magic-expo-app",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/involvex/create-magic-expo-app"
  },
  "funding": "https://github.com/sponsors/involvex",
  "author": {
    "name": "involvex"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "clean": "rimraf node_modules packages/app/node_modules packages/*/node_modules packages/*/dist",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prebuild": "bun run format && bun run lint:fix && bun run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/involvex"
  }
}
